{
  "name": "mandarin-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:analyze": "ANALYZE=true vite build --mode production",
    "build:optimized": "npm run purge:css && npm run lint && npm run build",
    "preview": "vite preview",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "serve:prod": "vite preview --host --port 3000",
    "purge:css": "purgecss --config purgecss.config.js",
    "analyze:bundle": "vite build --mode analyze && open stats.html",
    "optimize:images": "npx imagemin-cli public/images/**/* --out-dir=public/images/optimized",
    "perf:audit": "npm run build:optimized && npm run serve:prod"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "axios": "^1.8.3",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.6.3",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "lodash": "^4.17.21",
    "lucide-react": "^0.483.0",
    "peer": "^1.0.2",
    "peerjs": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.3.0",
    "react-toastify": "^11.0.5",
    "react-virtualized-auto-sizer": "^1.0.25",
    "react-window": "^1.8.11",
    "react-window-infinite-loader": "^1.0.10",
    "resend": "^4.2.0",
    "socket.io-client": "^4.8.1",
    "web-vitals": "^4.2.4",
    "webrtc-adapter": "^9.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-legacy": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "critical": "^5.1.2",
    "cssnano": "^7.0.6",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "imagemin-cli": "^7.0.0",
    "purgecss": "^5.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "vite": "^6.2.2",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.1",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-preload": "^0.3.1",
    "vite-plugin-purgecss": "^0.2.13"
  }
}
