# Production environment variables
# Use relative paths for better compatibility with reverse proxies like Nginx
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_UPLOADS_URL=/uploads
VITE_APP_NAME=Flirtss
VITE_APP_URL=https://flirtss.com

# Debugging flags - set to false after confirming everything works
VITE_DEBUG_SOCKET=true
VITE_DEBUG_CONNECTION=true